# =============================================================================
# Relighty - Git Ignore for Training in Cloud
# =============================================================================
# Push this to GitHub/Claude, download dataset on cloud machine

# -----------------------------------------------------------------------------
# Virtual Environment
# -----------------------------------------------------------------------------
.venv/
venv/
ENV/
env/

# -----------------------------------------------------------------------------
# Dataset - DON'T PUSH (keep on server or download separately)
# -----------------------------------------------------------------------------
# Original dataset
dataset/input/
dataset/target/
dataset/splits/
dataset/
# Processed dataset (PNG with transparent)
dataset_bg/
dataset_no_bg/
data/

# -----------------------------------------------------------------------------
# Model Checkpoints - Generate during training (optional to keep)
# -----------------------------------------------------------------------------
checkpoints/
*.pth

# BiSeNet weights - download separately, don't store binaries in Git
Masking/weights/*
!Masking/weights/.gitkeep

# Exclude .onnx (redundant, .pt is used)
*.onnx

# -----------------------------------------------------------------------------
# Training Outputs
# -----------------------------------------------------------------------------
logs/
Results/
*.log

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Debug/Test Files
# -----------------------------------------------------------------------------
debug_mask.py
*.tmp
*.temp

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# MediaPipe Models (will download automatically)
# -----------------------------------------------------------------------------
*.tflite
*.task
face_landmarker.task
selfie_segmenter.tflite
